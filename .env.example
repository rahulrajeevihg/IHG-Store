# ERPNext base URL
ERP_BASE_URL=http://167.71.204.41

# Preferred auth: token-based
ERP_API_KEY=
ERP_API_SECRET=

# Fallback auth (server-side only, do not expose to browser)
ERP_USERNAME=
ERP_PASSWORD=

# Sales-home dashboard ERP target (optional override).
# If set, the home dashboard uses these instead of the shared ERP_* vars above —
# useful when the dashboard's bench (igh_search app) differs from the main ERP host.
SALES_HOME_ERP_BASE_URL=
SALES_HOME_ERP_API_KEY=
SALES_HOME_ERP_API_SECRET=

# Sales home caching (5-15 min recommended)
SALES_HOME_CACHE_TTL_MS=600000

# Upstream timeout
ERP_TIMEOUT_MS=30000
